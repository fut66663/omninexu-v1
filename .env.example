# Application
OMNINEXU_ENV=development
OMNINEXU_LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://omninexu:omninexu@localhost:5432/omninexu

# Redis
REDIS_URL=redis://localhost:6379/0

# Data warehouse root directory (default: D:/OmniNexuData)
OMNINEXU_DATA_ROOT=D:/OmniNexuData

# SEC EDGAR (required — SEC rejects requests without a valid identity header)
EDGAR_IDENTITY=omninexu@example.com

# SimFin (sign up at simfin.com for a free API key to unlock quarterly data)
# SIMFIN_API_KEY=your_simfin_api_key

# FRED (Phase 1)
# FRED_API_KEY=your_fred_api_key

# API
API_HOST=0.0.0.0
API_PORT=8000
# Rate limiting deferred to Phase 1
# API_RATE_LIMIT=100/minute
